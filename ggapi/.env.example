# ggapi/.env — local to WEBSERVER. NEVER commit actual values.
# Copy this file to ggapi/.env and fill in real values.
# Production values are documented in docs/PRODUCTION_INVENTORY.md (kept out of git).

# ----- SQL Server (localhost on WEBSERVER itself) -----
SQL_SERVER=localhost
SQL_DATABASE=ggpickup
SQL_USER=sa
SQL_PASSWORD=CHANGE_ME
SQL_DRIVER={ODBC Driver 17 for SQL Server}

# ----- JWT -----
# Production secret is in main.py historically. Move it here:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

# ----- File storage (under D:\Data\Web\gg\ so IIS can serve them) -----
PHOTO_DIR=C:\ai\ggapi\photos
# Scanned images saved by /scan before OCR. Prod main.py historically used C:\ggscans.
SCAN_DIR=C:\ai\ggapi\scans

# ----- Google Sheets sync -----
GOOGLE_CREDENTIALS_PATH=C:\ai\ggapi\google-credentials.json
SHEET_ID=1TSJNTWouAV1x4W6Ouh3uTKM-PDNJL9952eYqYcjoPAA
SHEET_TAB=TODAY

# ----- OCR (Tesseract) -----
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

