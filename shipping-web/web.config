<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config for D:\Data\Web\shipping-web\

  This MIRRORS the production gg/ web.config behavior:
    Browser:  GET /api/shipping/today
    IIS rule: strip /api/    →  forward as
    FastAPI:  GET /shipping/today

  Prerequisites already installed on WEBSERVER:
    - URL Rewrite Module
    - Application Request Routing (ARR), with Server Proxy Settings → Enable proxy

  No additional install needed for this file. Just drop it next to index.html.
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- /api/* → http://localhost:8001/* (strip the /api/ prefix) -->
        <rule name="ShippingWeb API Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8001/{R:1}" />
        </rule>

        <!-- /photos/* → FastAPI static mount -->
        <rule name="ShippingWeb Photos Proxy" stopProcessing="true">
          <match url="^photos/(.*)" />
          <action type="Rewrite" url="http://localhost:8001/photos/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.00:05:00" />
    </staticContent>

    <urlCompression doStaticCompression="true" doDynamicCompression="false" />
    <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
